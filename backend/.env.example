# =============================================================================
# Research-Flow backend/.env 示例
# 1. 复制当前文件为 backend/.env
# 2. 凭证和本机专属覆盖项放在这里
# 3. 共享默认配置放在 backend/config/settings.toml
# =============================================================================

# -----------------------------------------------------------------------------
# Zotero MCP 凭证
# -----------------------------------------------------------------------------
ZOTERO_API_KEY=
ZOTERO_LIBRARY_ID=
UNPAYWALL_EMAIL=
UNSAFE_OPERATIONS=

# -----------------------------------------------------------------------------
# LLM 平台凭证
# 中转站只要兼容 OpenAI 协议，就都在 settings.toml 中写 provider_type = "openai_compatible"
# 然后在这里提供对应平台的 API key 即可
# 如果你想直接通过 .env 新增平台，也可以使用嵌套命名：
# LLM__PLATFORMS__OPENROUTER__PROVIDER_TYPE=openai_compatible
# LLM__PLATFORMS__OPENROUTER__BASE_URL=https://openrouter.ai/api/v1
# LLM__PLATFORMS__OPENROUTER__API_KEY=${OPENROUTER_API_KEY}
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ORGANIZATION=
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
DASHSCOPE_API_KEY=
QWEN_API_KEY=

# -----------------------------------------------------------------------------
# 可选本机覆盖项
# 只有当前机器需要覆盖 settings.toml 默认值时才添加
# 示例：ZOTERO_MCP_COMMAND=C:\path\to\zotero-mcp.exe
# -----------------------------------------------------------------------------
