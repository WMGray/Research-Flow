# =============================================================================
# Research-Flow backend/.env example
# Copy this file to backend/.env and fill local credentials only.
# Shared defaults and non-secret runtime options belong in backend/config/settings.toml.
# =============================================================================

# -----------------------------------------------------------------------------
# Zotero credentials
# -----------------------------------------------------------------------------
ZOTERO_API_KEY=
ZOTERO_LIBRARY_ID=
UNPAYWALL_EMAIL=
UNSAFE_OPERATIONS=

# -----------------------------------------------------------------------------
# LLM provider credentials
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
DASHSCOPE_API_KEY=
QWEN_API_KEY=

# -----------------------------------------------------------------------------
# MinerU credentials
# -----------------------------------------------------------------------------
RFLOW_MINERU_API_TOKEN=
