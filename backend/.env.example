# =============================================================================
# Research-Flow 后端环境变量配置模板
# 复制本文件为 .env 并填入真实值，.env 不会被提交到 Git
# =============================================================================

# -----------------------------------------------------------------------------
# 服务配置
# -----------------------------------------------------------------------------
APP_HOST=127.0.0.1
APP_PORT=8000
APP_ENV=development                  # development | production
APP_DEBUG=true

# -----------------------------------------------------------------------------
# 数据存储路径（本地优先，支持相对路径或绝对路径）
# -----------------------------------------------------------------------------
DATA_DIR=./data                      # 数据根目录
PDF_STORAGE_DIR=./data/pdfs          # PDF 文件存储目录
DB_PATH=./data/research_flow.db      # SQLite 数据库文件路径

# -----------------------------------------------------------------------------
# LLM 模型配置
# 各功能模块可独立指定使用哪个 Provider 和模型
# -----------------------------------------------------------------------------

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1   # 可替换为代理地址

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 通义千问 (Qwen)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 默认使用的模型（各模块未单独配置时的 fallback）
DEFAULT_LLM_PROVIDER=openai          # openai | anthropic | deepseek | qwen
DEFAULT_LLM_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# 论文来源 API
# -----------------------------------------------------------------------------

# Semantic Scholar（论文搜索、引用关系）
SEMANTIC_SCHOLAR_API_KEY=

# Arxiv（每日推送，免费无需 Key，留空即可）
ARXIV_API_KEY=

# Crossref（DOI 解析，免费无需 Key）
CROSSREF_MAILTO=your_email@example.com

# -----------------------------------------------------------------------------
# Zotero MCP（Agno 通过 stdio + .env 方式接入）
# 注意：真实密钥只放到 backend/.env 或系统环境变量中，不要提交到仓库。
# -----------------------------------------------------------------------------
ZOTERO_MCP_ENABLED=true
ZOTERO_MCP_COMMAND=zotero-mcp        # 若 uv tool 未加入 PATH，可改成绝对路径
ZOTERO_MCP_ARGS=serve
ZOTERO_MCP_TRANSPORT=stdio
ZOTERO_MCP_TIMEOUT_SECONDS=60
ZOTERO_API_KEY=
ZOTERO_LIBRARY_ID=
ZOTERO_LIBRARY_TYPE=user
ZOTERO_LOCAL=local                   # 支持 local/web/auto，也兼容 true/false
PYTHONIOENCODING=utf-8
PYTHONUTF8=1
UNPAYWALL_EMAIL=
UNSAFE_OPERATIONS=all

# -----------------------------------------------------------------------------
# 定时任务配置
# -----------------------------------------------------------------------------
DAILY_PAPER_PUSH_CRON=0 8 * * *     # 每日推送时间，默认早上 8 点
CONFERENCE_REFRESH_CRON=0 0 * * 1   # 会议信息刷新，默认每周一凌晨

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
LOG_DIR=./logs
