# =============================================================================
# Research-Flow backend/.env 示例
# 用法：
# 1. 复制为 backend/.env
# 2. 这里只放“本机覆盖项”和“敏感信息”
# 3. 通用默认值统一放在 backend/config/settings.toml
# =============================================================================

# -----------------------------------------------------------------------------
# App 覆盖项
# 只有本机需要覆盖默认值时再填写。
# -----------------------------------------------------------------------------
APP_HOST=127.0.0.1
APP_PORT=8000
APP_ENV=development
APP_DEBUG=true

# -----------------------------------------------------------------------------
# Zotero MCP 基础覆盖项
# 一般只需要保留默认值；若本机命令或模式不同，再改这里。
# -----------------------------------------------------------------------------
ZOTERO_MCP_ENABLED=true
ZOTERO_MCP_COMMAND=zotero-mcp
ZOTERO_MCP_ARGS=serve
ZOTERO_MCP_TRANSPORT=stdio
ZOTERO_MCP_TIMEOUT_SECONDS=60
ZOTERO_LIBRARY_TYPE=user
ZOTERO_LOCAL=local
PYTHONIOENCODING=utf-8
PYTHONUTF8=1

# -----------------------------------------------------------------------------
# Zotero MCP 敏感/本机专属配置
# 这些值通常不应进入仓库。
# -----------------------------------------------------------------------------
ZOTERO_API_KEY=
ZOTERO_LIBRARY_ID=
UNPAYWALL_EMAIL=
UNSAFE_OPERATIONS=all
