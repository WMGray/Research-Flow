# ============================================================
# Research-Flow .gitignore
# ============================================================

# ------------------------------------------------------------
# 环境变量（敏感信息，绝不提交）
# ------------------------------------------------------------
.env
.env.local
.env.*.local

# ------------------------------------------------------------
# Python / 后端
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# 虚拟环境
.venv/
venv/
env/
ENV/


# 包构建产物
*.egg-info/
dist/
build/
*.egg
*.whl
.uv-cache/
.uv/


# 类型检查 / 测试
.mypy_cache/
.dmypy.json
.ruff_cache/
.pytest_cache/
.pytest-*/
.pytest_tmp*/
.pytest-temp/
pytest-cache-files-*/
reports/
skill-lab/
backend/.pytest-basetemp/
backend/.pytest-basetemp*/
backend/.pytest-codex-run/
backend/.pytest-codex-run*/
backend/.pytest-*/
backend/.pytest_tmp*/
backend/.codex*/
backend/.smoke-tmp/
backend/.uv-cache/
backend/acl_probe_pytest_mode/
backend/codex_tmp/
backend/pytest_*/
backend/tmp*/
tmp_pytest/
.pytest-local-*/
.tmp*/
pytest_tmp*/
data/tmp/
.coverage
coverage.xml
htmlcov/

# ------------------------------------------------------------
# Node.js / 前端
# ------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# 构建产物
frontend/dist/
frontend/build/
frontend/.vite/

# 缓存
.eslintcache
.stylelintcache
*.tsbuildinfo

# ------------------------------------------------------------
# 数据库 / 本地数据文件
# ------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
backend/storage/

# Keep only placeholder files for the versioned data directory structure.
backend/data/**
!backend/data/
!backend/data/**/
!backend/data/**/.gitkeep

# Runtime-only data directories should not be versioned.
backend/data/archive/
backend/data/tmp/
backend/data/upload/
backend/data/uploads/

# ------------------------------------------------------------
# 日志
# ------------------------------------------------------------
*.log
logs/
*.log.*

# ------------------------------------------------------------
# IDE / 编辑器
# ------------------------------------------------------------
.vscode/
.idea/
.claude/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ------------------------------------------------------------
# 操作系统
# ------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ------------------------------------------------------------
# 其他
# ------------------------------------------------------------
*.bak
*.tmp
*.temp
.cache/
