# ============================================================
# Research-Flow .gitignore
# ============================================================

# ------------------------------------------------------------
# 环境变量（敏感信息，绝不提交）
# ------------------------------------------------------------
.env
.env.local
.env.*.local

# ------------------------------------------------------------
# Python / 后端
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# 虚拟环境
.venv/
venv/
env/
ENV/

# 包构建产物
*.egg-info/
dist/
build/
*.egg
*.whl

# 类型检查 / 测试
.mypy_cache/
.dmypy.json
.ruff_cache/
.pytest_cache/
backend/tmp*/
.coverage
coverage.xml
htmlcov/

# ------------------------------------------------------------
# Node.js / 前端
# ------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# 构建产物
frontend/dist/
frontend/build/
frontend/.vite/

# 缓存
.eslintcache
.stylelintcache

# ------------------------------------------------------------
# 数据库 / 本地数据文件
# ------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
backend/data/
backend/storage/

# ------------------------------------------------------------
# 日志
# ------------------------------------------------------------
*.log
logs/
*.log.*

# ------------------------------------------------------------
# IDE / 编辑器
# ------------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ------------------------------------------------------------
# 操作系统
# ------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ------------------------------------------------------------
# 其他
# ------------------------------------------------------------
*.bak
*.tmp
*.temp
.cache/
